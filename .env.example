# OpenCLAW Mission Control — Environment Variables
#
# For VPS deployment (recommended): copy to .env.local
# For Vercel deployment: add these in Vercel dashboard → Settings → Environment Variables

# Gateway URL — use localhost when running on the same VPS as OpenClaw
OPENCLAW_GATEWAY_URL=http://127.0.0.1:18789

# Authentication token (from ~/.openclaw/openclaw.json → gateway.auth.token)
OPENCLAW_GATEWAY_TOKEN=your-gateway-token-here
